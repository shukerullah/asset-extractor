# ─── API ──────────────────────────────────────────────────────────────────────
# URL of the backend API.
# Development: defaults to http://localhost:8000
# Production: set to your backend URL (e.g. https://your-api.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Limits ───────────────────────────────────────────────────────────────────
# Maximum selections per image. Leave empty for unlimited.
# NEXT_PUBLIC_MAX_SELECTIONS=5
