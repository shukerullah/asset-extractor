# ─── AI Model ─────────────────────────────────────────────────────────────────
# silueta        → 43MB,  fast,     good quality (recommended for hosted)
# isnet-general-use → 179MB, moderate, high quality (recommended for self-hosting)
# u2net          → 176MB, moderate, good quality
# u2netp         → 4MB,   fastest,  basic quality
# birefnet-general → ~900MB, slow,   best quality (GPU only)
MODEL_NAME=silueta

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call this API.
# Production: set to your Vercel domain(s).
ALLOWED_ORIGINS=http://localhost:3000

# ─── Limits ───────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
RATE_LIMIT_PER_MIN=30

# ─── Server ───────────────────────────────────────────────────────────────────
# PORT is set automatically by most platforms (Render, Railway, etc).
# Override for local Docker.
# PORT=8000
# LOG_LEVEL=info
